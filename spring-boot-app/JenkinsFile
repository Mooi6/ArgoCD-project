pipeline {
    agent {
        node {
            label 'kali-agent'
        }
    }

    environment {
        DOCKERHUB_USERNAME       = 'm066' 
        DOCKER_IMAGE_NAME        = "${DOCKERHUB_USERNAME}/spring-boot-app"
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-credentials-id'
        GITHUB_CREDENTIALS_ID    = 'github-credentials-id'
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test with Maven') {
            steps {
                echo 'Building Application...'
                // الدخول للمجلد اللي جواه الـ pom.xml فعلياً
                dir('spring-boot-app') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis (Secops)') {
            steps {
                echo 'Running SonarQube Code Quality Scan...'
                withSonarQubeEnv('sonar-server') {
                    dir('spring-boot-app') {
                        sh 'mvn sonar:sonar'
                    }
                }
            }
        }

        stage('Trivy FS Scan (Security)') {
            steps {
                echo 'Scanning File System for Vulnerabilities...'
                dir('spring-boot-app') {
                    sh 'trivy fs . --severity HIGH,CRITICAL'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker Image...'
                dir('spring-boot-app') {
                    sh "docker build -t ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER} ."
                }
            }
        }

        stage('Trivy Image Scan (Security)') {
            steps {
                echo 'Scanning Docker Image with Trivy...'
                sh "trivy image ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER} --severity HIGH,CRITICAL"
            }
        }

        stage('Push to Docker Hub') {
            steps {
                echo 'Pushing Secure Image to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS_ID}", passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    sh "echo \${DOCKER_PASSWORD} | docker login -u \${DOCKER_USERNAME} --password-stdin"
                    sh "docker push ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                }
            }
        }

        stage('Update GitOps Manifests') {
            steps {
                echo 'Updating Deployment Configuration...'
                withCredentials([usernamePassword(credentialsId: "${GITHUB_CREDENTIALS_ID}", passwordVariable: 'GITHUB_TOKEN', usernameVariable: 'GITHUB_USER')]) {
                    
                    // التعديل في مجلد المانيفستس الموجود في الـ Root برة
                    sh "sed -i 's|image: .*|image: ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}|g' spring-boot-app-manifests/deployment.yml"
                    
                    sh """
                        git config user.email "jenkins@local.com"
                        git config user.name "Jenkins CI"
                        git add spring-boot-app-manifests/deployment.yml
                        git commit -m "Update image tag to ${BUILD_NUMBER} [skip ci]"
                        git push https://\${GITHUB_TOKEN}@github.com/\${GITHUB_USER}/ArgoCD-project.git HEAD:main
                    """
                }
            }
        }
    }
}
